PORT=8080
NODE_ENV=development
APP_SECRET=change-this-in-production
ADMIN_USER=admin
ADMIN_PASSWORD=change-me
COOKIE_SECURE=false
DEFAULT_TENANT_ID=default-org
DEFAULT_ORG_NAME=默认机构
DEFAULT_TRIAL_DAYS=14
DEFAULT_MONTHLY_AI_TOKENS=200000
DEFAULT_MONTHLY_AI_PAGES=1000
MAX_UPLOAD_MB=80
MAX_IMAGE_UPLOAD_MB=12
RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT=240
LOGIN_RATE_LIMIT=12
UPLOAD_RATE_LIMIT=20

# Storage: json is the local default. Use postgres for production.
STORAGE_DRIVER=json
DATABASE_URL=postgres://zenox:password@localhost:5432/zenox_exercise
POSTGRES_STATE_ID=zenox-app-state
POSTGRES_SYNC_RELATIONAL=true

# File storage: local is the development default. Use s3 for OSS/COS/MinIO/S3-compatible storage.
FILE_STORAGE_DRIVER=local
S3_BUCKET=zenox-exercise
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=zenox
S3_SECRET_ACCESS_KEY=zenox-password
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=

# Qianwen / DashScope OpenAI-compatible API
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
QWEN_VISION_MODEL=qwen-vl-plus
ALLOW_MISSING_QWEN_API_KEY=false
ALLOW_AI_FREE_VARIANTS=false

# Online similar-question search. disabled by default.
# WEB_SEARCH_PROVIDER supports: tavily, bing, serpapi, custom.
# Recommended provider: tavily.
WEB_SEARCH_PROVIDER=disabled
WEB_SEARCH_API_KEY=
WEB_SEARCH_ENDPOINT=
WEB_SEARCH_ENGINE=baidu
WEB_SEARCH_LIMIT=8
WEB_SEARCH_TIMEOUT_MS=12000

OCR_PROVIDER=qwen
OCR_LAYOUT_PROVIDER=qwen
OCR_LAYOUT_ENABLED=true
OCR_PREPROCESS=true
PDF_RENDER_DPI=220
PROMPT_VERSION=analysis-v2
