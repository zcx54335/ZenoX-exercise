# Docker 配置模板
#
# 不要把真实 deploy/docker.env 提交到 Git。
# 推荐执行 npm run docker:config 自动生成本机专用配置。

PORT=8080
NODE_ENV=production
APP_SECRET=CHANGE_ME_AT_LEAST_32_CHARS
ADMIN_USER=admin
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
COOKIE_SECURE=false

DEFAULT_TENANT_ID=default-org
DEFAULT_ORG_NAME=默认机构
DEFAULT_TRIAL_DAYS=14
DEFAULT_MONTHLY_AI_TOKENS=200000
DEFAULT_MONTHLY_AI_PAGES=1000
MAX_UPLOAD_MB=80
MAX_IMAGE_UPLOAD_MB=12
TMP_FILE_TTL_HOURS=168
RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT=240
LOGIN_RATE_LIMIT=12
UPLOAD_RATE_LIMIT=20

STORAGE_DRIVER=postgres
POSTGRES_DB=zenox_exercise
POSTGRES_USER=zenox
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
DATABASE_URL=postgres://zenox:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/zenox_exercise
POSTGRES_STATE_ID=zenox-app-state
POSTGRES_SYNC_RELATIONAL=true
POSTGRES_SSL=false

FILE_STORAGE_DRIVER=s3
MINIO_ROOT_USER=zenox
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD
S3_BUCKET=zenox-exercise
S3_REGION=us-east-1
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY_ID=zenox
S3_SECRET_ACCESS_KEY=CHANGE_ME_MINIO_PASSWORD
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=

QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
QWEN_VISION_MODEL=qwen-vl-plus
ALLOW_MISSING_QWEN_API_KEY=true
ALLOW_AI_FREE_VARIANTS=false

# Online similar-question search. Set provider/key to enable "AI查题".
# Recommended provider: tavily. Other providers: bing, serpapi, custom.
WEB_SEARCH_PROVIDER=disabled
WEB_SEARCH_API_KEY=
WEB_SEARCH_ENDPOINT=
WEB_SEARCH_ENGINE=baidu
WEB_SEARCH_LIMIT=8
WEB_SEARCH_TIMEOUT_MS=12000

OCR_PROVIDER=qwen
OCR_LAYOUT_PROVIDER=qwen
OCR_LAYOUT_ENABLED=true
OCR_PREPROCESS=true
PDF_RENDER_DPI=220
PROMPT_VERSION=analysis-v2
