{
  "name": "zenox-exercise",
  "version": "1.0.0",
  "description": "Tutor exercise organizer and worksheet generator",
  "main": "server/index.js",
  "type": "module",
  "scripts": {
    "start": "node scripts/start.js",
    "dev": "node scripts/start.js --watch",
    "docker:config": "node scripts/create-docker-env.js",
    "docker:up": "docker compose up -d --build",
    "docker:up:cn": "docker compose -f docker-compose.yml -f docker-compose.cn.yml up -d --build",
    "reset-data": "node scripts/reset-data.js",
    "migrate:postgres": "node scripts/migrate-json-to-postgres.js",
    "migrate:uploads:s3": "node scripts/migrate-uploads-to-s3.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1076.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.22.0"
  }
}
